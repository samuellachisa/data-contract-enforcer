{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "doc_id",
    "status",
    "bytes"
  ],
  "properties": {
    "doc_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": [
        "done",
        "failed"
      ]
    },
    "bytes": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}