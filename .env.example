# Copy to `.env` in the repo root and fill in values. Both `.env` and `.env.local` are gitignored.
# Load order: `.env` first, then `.env.local` (overrides). Shell/CI variables still win over `.env`.

# --- OpenAI (embeddings in ai_extensions + optional contract annotations in generator) ---
# OPENAI_API_KEY=sk-...
# CONTRACT_LLM_MODEL=gpt-4o-mini
# EMBEDDING_OFF=1

# --- Anthropic (contract column annotations; tried before OpenAI in generator) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CONTRACT_MODEL=claude-3-5-haiku-20241022

# --- OpenRouter (OpenAI-compatible API; chat in generator, optional embeddings in ai_extensions) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/your-repo
# OPENROUTER_X_TITLE=Week7-DataContractEnforcer
# USE_OPENROUTER_EMBEDDINGS=1

# --- AI extensions thresholds (contracts/ai_extensions.py); CLI flags override env ---
# CONTRACT_AI_EMBEDDING_DRIFT_THRESHOLD=0.15
# CONTRACT_AI_EMBEDDING_SAMPLE_SIZE=200
# CONTRACT_AI_LLM_VIOLATION_TREND_MULTIPLIER=1.5
# CONTRACT_AI_LLM_VIOLATION_TREND_MIN_DELTA=0.001
# CONTRACT_AI_PROMPT_PREVIEW_MAX_LENGTH=8000
# CONTRACT_AI_HASHING_N_FEATURES=384
# CONTRACT_AI_MONITORING_OUTPUT_PATH=validation_reports/ai_monitoring_metrics.json
# CONTRACT_AI_MONITORING_DISABLE=1

# --- Report generator (contracts/report_generator.py): violation pagination + health score type weights ---
# CONTRACT_REPORT_VIOLATIONS_PAGE=0
# CONTRACT_REPORT_VIOLATIONS_PAGE_SIZE=3
# Optional JSON: prefix -> multiplier (longest prefix wins on check_id). Merged with enforcer_report/health_type_weights.json if present.
# CONTRACT_REPORT_HEALTH_TYPE_WEIGHTS={"week3.":1.5,"langsmith.":0.5}

# --- Generator flags ---
# CONTRACT_LLM_OFF=1
# USE_YDATA=1

# --- Seed outputs (scripts/seed_outputs.py): Week 3 Document Refinery paths for extractions.jsonl ---
# WEEK3_DOCUMENT_REFINERY_ROOT=/absolute/path/to/Week 3 (Document Refinery)
# Optional: folder containing PDFs (default: <WEEK3_DOCUMENT_REFINERY_ROOT>/data)
# WEEK3_DOCUMENT_REFINERY_DATA_DIR=/absolute/path/to/Week 3 (Document Refinery)/data

# Seed: run real Week 3 ExtractionRouter on each PDF (slow; needs docrefinery env). 0 = pdfplumber only.
# SEED_WEEK3_REFINERY=0
