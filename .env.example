# Copy to `.env` in the repo root and fill in values. Both `.env` and `.env.local` are gitignored.
# Load order: `.env` first, then `.env.local` (overrides). Shell/CI variables still win over `.env`.

# --- OpenAI (embeddings in ai_extensions + optional contract annotations in generator) ---
# OPENAI_API_KEY=sk-...
# CONTRACT_LLM_MODEL=gpt-4o-mini
# EMBEDDING_OFF=1

# --- Anthropic (contract column annotations; tried before OpenAI in generator) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CONTRACT_MODEL=claude-3-5-haiku-20241022

# --- OpenRouter (OpenAI-compatible API; chat in generator, optional embeddings in ai_extensions) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/your-repo
# OPENROUTER_X_TITLE=Week7-DataContractEnforcer
# USE_OPENROUTER_EMBEDDINGS=1

# --- Generator flags ---
# CONTRACT_LLM_OFF=1
# USE_YDATA=1
